And Yes You Are Right — Per Table Only
Since ON SCHEMA doesn't work with WHEN condition we need the same loop script but this time filtering for SYSADM user coming from those tools.
Script — Drop Old and Recreate Per Table with Program Filter
Script 1 — Drop Existing Per Table Policies
SET SERVEROUT ON SIZE UNLIMITED
DECLARE
    policy_not_found EXCEPTION;
    PRAGMA EXCEPTION_INIT(policy_not_found, -46357);
BEGIN
    FOR p IN (
        SELECT DISTINCT policy_name
        FROM audit_unified_enabled_policies
        WHERE policy_name LIKE 'AUDIT_SYSADM_%'
    )
    LOOP
        BEGIN
            EXECUTE IMMEDIATE
                'NOAUDIT POLICY ' || p.policy_name;
            EXECUTE IMMEDIATE
                'DROP AUDIT POLICY ' || p.policy_name;
            DBMS_OUTPUT.PUT_LINE(
                'Dropped: ' || p.policy_name);
        EXCEPTION
            WHEN policy_not_found THEN
                NULL;
            WHEN OTHERS THEN
                DBMS_OUTPUT.PUT_LINE(
                    'Error: ' || SQLERRM);
        END;
    END LOOP;
    DBMS_OUTPUT.PUT_LINE('Drop complete');
END;
/
Script 2 — Recreate Per Table with TWO WHEN Conditions
This creates two policies per table:
Policy A — catches non-SYSADM users
Policy B — catches SYSADM when using psdmt.exe or pside.exe
SET SERVEROUT ON SIZE UNLIMITED
DECLARE
    l_sql_stmt    VARCHAR2(32767);
    l_policy_name VARCHAR2(128);
    l_count_a     NUMBER := 0;
    l_count_b     NUMBER := 0;
    l_skipped     NUMBER := 0;
    l_errors      NUMBER := 0;

    policy_exists EXCEPTION;
    PRAGMA EXCEPTION_INIT(policy_exists, -46358);

BEGIN
    FOR t IN (
        SELECT table_name
        FROM dba_tables
        WHERE owner = 'SYSADM'
        ORDER BY table_name
    )
    LOOP
        -- POLICY A
        -- Catch all NON-SYSADM users
        l_policy_name := SUBSTR(
            'AUDIT_SYSADM_A_' || LOWER(t.table_name),
            1, 128
        );

        BEGIN
            l_sql_stmt :=
                'CREATE AUDIT POLICY ' ||
                l_policy_name ||
                ' ACTIONS INSERT, UPDATE, DELETE' ||
                ' ON sysadm.' || t.table_name ||
                ' WHEN ''SYS_CONTEXT(''''USERENV'''',' ||
                '''''SESSION_USER'''')' ||
                ' != ''''SYSADM''''' ||
                ''' EVALUATE PER SESSION';

            EXECUTE IMMEDIATE l_sql_stmt;
            EXECUTE IMMEDIATE
                'AUDIT POLICY ' || l_policy_name;
            l_count_a := l_count_a + 1;

        EXCEPTION
            WHEN policy_exists THEN
                l_skipped := l_skipped + 1;
            WHEN OTHERS THEN
                l_errors := l_errors + 1;
                IF l_errors <= 10 THEN
                    DBMS_OUTPUT.PUT_LINE(
                        'Error A ' || t.table_name ||
                        ': ' || SQLERRM);
                END IF;
        END;

        -- POLICY B
        -- Catch SYSADM using psdmt.exe or pside.exe
        l_policy_name := SUBSTR(
            'AUDIT_SYSADM_B_' || LOWER(t.table_name),
            1, 128
        );

        BEGIN
            l_sql_stmt :=
                'CREATE AUDIT POLICY ' ||
                l_policy_name ||
                ' ACTIONS INSERT, UPDATE, DELETE' ||
                ' ON sysadm.' || t.table_name ||
                ' WHEN ''SYS_CONTEXT(''''USERENV'''',' ||
                '''''SESSION_USER'''') = ''''SYSADM''''' ||
                ' AND SYS_CONTEXT(''''USERENV'''',' ||
                '''''MODULE'''')' ||
                ' IN (''''psdmt.exe'''',''''pside.exe'''''||
                ')''' ||
                ' EVALUATE PER SESSION';

            EXECUTE IMMEDIATE l_sql_stmt;
            EXECUTE IMMEDIATE
                'AUDIT POLICY ' || l_policy_name;
            l_count_b := l_count_b + 1;

            IF MOD(l_count_b, 50) = 0 THEN
                DBMS_OUTPUT.PUT_LINE(
                    'Progress: ' || l_count_b ||
                    ' B policies created...');
            END IF;

        EXCEPTION
            WHEN policy_exists THEN
                l_skipped := l_skipped + 1;
            WHEN OTHERS THEN
                l_errors := l_errors + 1;
                IF l_errors <= 10 THEN
                    DBMS_OUTPUT.PUT_LINE(
                        'Error B ' || t.table_name ||
                        ': ' || SQLERRM);
                END IF;
        END;

    END LOOP;

    DBMS_OUTPUT.PUT_LINE('======================');
    DBMS_OUTPUT.PUT_LINE('COMPLETE');
    DBMS_OUTPUT.PUT_LINE('A policies: ' || l_count_a);
    DBMS_OUTPUT.PUT_LINE('B policies: ' || l_count_b);
    DBMS_OUTPUT.PUT_LINE('Skipped   : ' || l_skipped);
    DBMS_OUTPUT.PUT_LINE('Errors    : ' || l_errors);
    DBMS_OUTPUT.PUT_LINE('======================');

END;
/
Verify After Running
-- Count both policy types
SELECT
    CASE
        WHEN policy_name LIKE 'AUDIT_SYSADM_A_%'
        THEN 'Non-SYSADM users'
        WHEN policy_name LIKE 'AUDIT_SYSADM_B_%'
        THEN 'SYSADM via psdmt/pside'
    END AS policy_type,
    COUNT(*) AS total
FROM audit_unified_enabled_policies
WHERE policy_name LIKE 'AUDIT_SYSADM_%'
GROUP BY
    CASE
        WHEN policy_name LIKE 'AUDIT_SYSADM_A_%'
        THEN 'Non-SYSADM users'
        WHEN policy_name LIKE 'AUDIT_SYSADM_B_%'
        THEN 'SYSADM via psdmt/pside'
    END;
